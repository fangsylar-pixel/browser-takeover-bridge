{
  "manifest_version": 3,
  "name": "Browser Takeover — Local AI Bridge",
  "description": "Securely connect local AI agents to already-open, authenticated Chrome and Edge tabs.",
  "version": "0.6.0",
  "permissions": [
    "tabs",
    "scripting",
    "activeTab",
    "storage",
    "alarms",
    "downloads",
    "debugger"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Browser Takeover — Local AI Bridge",
    "default_popup": "popup.html"
  }
}
